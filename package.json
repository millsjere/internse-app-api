{
  "name": "internse-api",
  "version": "1.0.0",
  "description": "Modern Express API for internseApp job marketplace",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsc && nodemon dist/index.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "create-test-accounts": "node dist/scripts/create-test-accounts.js",
    "migrate:plans": "node dist/scripts/migrate-plans.js",
    "seed:admin": "node dist/scripts/seed-admin.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "resend": "^3.0.0",
    "socket.io": "^4.5.0",
    "slugify": "^1.6.6",
    "cookie-parser": "^1.4.6",
    "morgan": "^1.10.0",
    "sharp": "^0.32.0",
    "cloudinary": "^1.35.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^18.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/multer": "^1.4.7",
    "@types/cookie-parser": "^1.4.3",
    "@types/morgan": "^1.9.4",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "@typescript-eslint/parser": "^5.50.0",
    "eslint": "^8.30.0",
    "nodemon": "^3.0.1",
    "prettier": "^2.8.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.0"
  }
}
